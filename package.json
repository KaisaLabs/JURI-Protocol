{
  "name": "juri-protocol",
  "version": "0.1.0",
  "private": true,
  "description": "⚖️ JURI Protocol — DeFi Exploit Forensics & Cross-Chain Knowledge Base",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "agent:orchestrator": "pnpm --filter agents orchestrator",
    "agent:typecheck": "pnpm --filter agents typecheck",
    "contract:compile": "pnpm --filter contracts run compile",
    "contract:deploy": "pnpm --filter contracts run deploy",
    "setup": "bash scripts/setup.sh",
    "test:storage": "cd agents && npx tsx ../scripts/test-storage.ts",
    "test:contracts": "pnpm --filter contracts test",
    "setup:storage": "cd agents && npx tsx ../scripts/test-storage.ts",
    "test:e2e": "bash -c 'for p in 4000 9091 9092 9093 9101 9102 9103; do lsof -ti :$p 2>/dev/null | xargs kill -9 2>/dev/null; done; sleep 2' && cd agents && npx tsx ../scripts/e2e-test.ts",
    "start": "cd agents && npx tsx ../scripts/e2e-test.ts",
    "agent:forensic": "pnpm --filter agents run forensic",
    "agent:analysis": "pnpm --filter agents run analysis",
    "agent:verification": "pnpm --filter agents run verification"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
