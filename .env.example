# ============================
# ⚖️  Agent Court Environment
# ============================

# ── Wallet ─────────────────────────────────
PRIVATE_KEY=0x_your_private_key_here
# Generate: cast wallet new
# Fund:     https://faucet.0g.ai (0.1 0G/day)
# Fund:     https://cloud.google.com/application/web3/faucet/0g/galileo

# ── 0G Chain (Galileo Testnet, Chain ID 16602) ──
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602

# ── 0G Storage (Turbo mode) ────────────────
# Tested SDK: @0gfoundation/0g-ts-sdk v1.2.6
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
ZG_KV_NODE=http://3.101.147.150:6789
ZG_STORAGE_NETWORK=testnet
ZG_FLOW_CONTRACT=0xbD75117F80b4E22698D0Cd7612d92BDb8eaff628
# Verify uploads: https://storagescan-galileo.0g.ai

# ── 0G Compute (Sealed TEE Inference) ──────
# Setup: https://build.0g.ai/compute/
ZG_SERVICE_URL=your_0g_compute_service_url
ZG_API_SECRET=app-sk-your_0g_compute_secret
# Models: qwen/qwen-2.5-7b-instruct, google/gemma-3-27b-it, etc.

# ── Custom LLM (Plaintiff & Defendant) ─────
CUSTOM_LLM_URL=your_custom_llm_base_url
CUSTOM_LLM_KEY=your_custom_llm_key
CUSTOM_LLM_MODEL=glm-5

# ── KeeperHub (Execution Layer) ────────────
# Get key: app.keeperhub.com → API Keys → Organization
KEEPERHUB_API_KEY=kh_your_org_scoped_key

# ── Gensyn AXL (P2P Communication) ────────
# Setup: clone https://github.com/gensyn-ai/axl + go build
AXL_REPO_PATH=../axl
AXL_PLAINTIFF_PORT=9001
AXL_DEFENDANT_PORT=9002
AXL_JUDGE_PORT=9003
# Transport mode: axl (production) or direct (dev/test)
AGENT_TRANSPORT=direct
# Shared secret for internal POST control-plane/runtime APIs.
# Required by orchestrator and all agents.
AGENT_CONTROL_TOKEN=964681f16f120a97ec2187cb7e9d8fcf2ae84ea92f878ad99ecf18774f7f16be
PLAINTIFF_CONTROL_PORT=9101
DEFENDANT_CONTROL_PORT=9102
JUDGE_CONTROL_PORT=9103

# ── Orchestrator ───────────────────────────
API_PORT=4000
ORCHESTRATOR_URL=http://127.0.0.1:4000
CONTRACT_ADDRESS=0x_your_deployed_agentcourt_address

# ── Agent Wallets ───────────────────────────
# For contract-backed create/join/resolve/withdraw flows, PLAINTIFF_KEY,
# DEFENDANT_KEY, and JUDGE_KEY are all required and must be distinct.
# Optional *_ADDRESS values must match their corresponding key.
PLAINTIFF_KEY=0x3341c058bcc0dc4fd4efacf5a525a59aa82810ba5eca91d4a1b4964bef23adb8
DEFENDANT_KEY=0xaf32f44646aaf8952ac27fb779bef3658090d0b444e94145baafa5bd23fa53bc
JUDGE_KEY=0x7fc9323449268d4e877b2b460d98e0460d35fbb1800065cc4df1d73e60a87310
PLAINTIFF_ADDRESS=0x03D5F8302533E10A62fF79eaE969520A18E47219
DEFENDANT_ADDRESS=0xAEFa858f9Cf00260247B2C848f1da31d1D65B757
JUDGE_ADDRESS=0x8c675EbEE7531672769022e37768D7Fa150B1441
